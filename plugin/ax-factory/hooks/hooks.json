{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hook-recorder.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hook-recorder.mjs\"",
            "timeout": 15,
            "statusMessage": "Connecting session to AX Factory"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hook-recorder.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hook-recorder.mjs\"",
            "timeout": 15,
            "statusMessage": "Starting AX Factory work"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hook-recorder.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hook-recorder.mjs\"",
            "timeout": 15,
            "statusMessage": "Recording approval wait"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hook-recorder.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hook-recorder.mjs\"",
            "timeout": 15,
            "statusMessage": "Updating AX Factory state"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hook-recorder.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hook-recorder.mjs\"",
            "timeout": 15,
            "statusMessage": "Closing AX Factory run"
          }
        ]
      }
    ]
  }
}
